msgstr "Pertsonalizatu HTMLa <HEAD>"

#: askbot/conf/skin_general_settings.py:157
msgid "Custom portion of the HTML <HEAD>"
msgstr "HTMLaren zati pertsonalizatua <HEAD>"

#: askbot/conf/skin_general_settings.py:159
msgid ""
"<strong>To use this option</strong>, check \"Customize HTML &lt;HEAD&gt;\" "
"above. Contents of this box will be inserted into the &lt;HEAD&gt; portion "
"of the HTML output, where elements such as &lt;script&gt;, &lt;link&gt;, "
"&lt;meta&gt; may be added. Please, keep in mind that adding external "
"javascript to the &lt;HEAD&gt; is not recommended because it slows loading "
"of the pages. Instead, it will be more efficient to place links to the "
"javascript files into the footer. <strong>Note:</strong> if you do use this "
"setting, please test the site with the W3C HTML validator service."
msgstr ""
"<strong>Aukera hau erabiltzeko</strong>, markatu \"Pertsonalizatu HTML "
"&lt;HEAD&gt;\" goian.Kutxa honetako edukiak HTMLaren &lt;HEAD&gt; atalean "
"txertatuko dira,  &lt;script&gt;, &lt;link&gt; edo &lt;meta&gt; bezalako "
"elementuak sartu ahal dira.\n"
"Kontuan izan ez dela aholkatzen &lt;HEAD&gt;  atalean kanpo javascripta "
"sartzea, orrien karga moteltzen duelako. Horren ordez, javascript "
"fitxategietara esteka orriaren oinean sartu daiteke. <strong>Oharra:</"
"strong> ezarpen hau erabiltzen baduzu, egiaztatu gunea W3C HTML balidazio "
"zerbitzuarekin."

#: askbot/conf/skin_general_settings.py:178
msgid "Custom header additions"
msgstr "Pertsonalizatutako goiburuaren gehigarriak"

#: askbot/conf/skin_general_settings.py:180
msgid ""
"Header is the bar at the top of the content that contains user info and site "
"links, and is common to all pages. Use this area to enter contents of the "
"header in the HTML format. When customizing the site header (as well as "
"footer and the HTML &lt;HEAD&gt;), use the HTML validation service to make "
"sure that your input is valid and works well in all browsers."
msgstr ""

#: askbot/conf/skin_general_settings.py:193
msgid "Site footer mode"
msgstr "Webgunearen oinaren modua"

#: askbot/conf/skin_general_settings.py:195
msgid ""
"Footer is the bottom portion of the content, which is common to all pages. "
"You can disable, customize, or use the default footer."
msgstr ""
"Oina edukiaren beheko zatia da, orri guztietan erakusten dena. Oin "
"lehenetsia desgaitu, pertsonalizatu edo erabili egin dezakezu."

#: askbot/conf/skin_general_settings.py:213
msgid "Custom footer (HTML format)"
msgstr "Oin pertsonalizatua (HTML formatua)"

#: askbot/conf/skin_general_settings.py:215
msgid ""
"<strong>To enable this function</strong>, please select option 'customize' "
"in the \"Site footer mode\" above. Use this area to enter contents of the "
"footer in the HTML format. When customizing the site footer (as well as the "
"header and HTML &lt;HEAD&gt;), use the HTML validation service to make sure "
"that your input is valid and works well in all browsers."
msgstr ""
"<strong>Funtzio hau gaitzeko</strong>, aukeratu 'pertsonalizatu' aukera "
"goiko \"Gunearen orri-oin modua\"n. Erabili eremu hau orri-oinaren edukiak "
"HTML formatuan  sartzeko. Gunearen orri-oina pertsonalizatzean  (edo orri-"
"oina, edo &lt;HEAD&gt; atala), erabili HTML balidazio zerbitzu bat zure "
"edukia baliozkoa dela eta nabigatzaile guztietan ondo ikusiko dela "
"egiaztatzeko."

#: askbot/conf/skin_general_settings.py:228
msgid "Apply custom style sheet (CSS)"
msgstr "Aplikatu estilo-orri pertsonalizatua (CSS)"

#: askbot/conf/skin_general_settings.py:230
msgid ""
"Check if you want to change appearance of your form by adding custom style "
"sheet rules (please see the next item)"
msgstr ""
"Sakatu hau zure inprimakiaren itxura aldatu nahi baduzu estilo orrialdeetan "
"pertsonalizatutako neurriak gehituz (ikusi hurrengo elementua)"

#: askbot/conf/skin_general_settings.py:240
msgid "Custom style sheet (CSS)"
msgstr "Estilo-orri pertsonalizatua (CSS)"

#: askbot/conf/skin_general_settings.py:243
msgid ""
"<strong>To use this function</strong>, check \"Apply custom style sheet\" "
"option above. The CSS rules added in this window will be applied after the "
"default style sheet rules. The custom style sheet will be served dynamically "
"at url \"&lt;forum url&gt;/custom.css\", where the \"&lt;forum url&gt; part "
"depends (default is empty string) on the url configuration in your urls.py."
msgstr ""
"<strong>Funtzio hau erabiltzeko</strong>, Markatu \"Aplikatu estilo orri "
"pertsonalizatua\" goian. Leiho honetan gehitutako CSS arauek lehenetsitako "
"estilo orrietako arauen ondoren aplikatuko dira. Pertsonalizatutako estilo "
"orria dinamikoki zerbitzatuko da \"&lt;forum url&gt;/custom.css\" URLan, non "
"\"&lt;forum url&gt; zure urls.py konfigurazioaren menpekoa den (lehenetsita "
"kate huts bat da)."

#: askbot/conf/skin_general_settings.py:257
msgid "Add custom javascript"
msgstr "Gehitu Javascript pertsonalizatua"

#: askbot/conf/skin_general_settings.py:260
msgid "Check to enable javascript that you can enter in the next field"
msgstr "Markatu Javascript gaitzeko eta hurrengo eremuan sartu ahal izateko"

#: askbot/conf/skin_general_settings.py:268
msgid "Custom javascript"
msgstr "Javascript pertsonalizatua"

#: askbot/conf/skin_general_settings.py:271
msgid ""
"Type or paste plain javascript that you would like to run on your site. Link "
"to the script will be inserted at the bottom of the HTML output and will be "
"served at the url \"&lt;forum url&gt;/custom.js\". Please, bear in mind that "
"your javascript code may break other functionalities of the site and that "
"the behavior may not be consistent across different browsers (<strong>to "
"enable your custom code</strong>, check \"Add custom javascript\" option "
"above)."
msgstr ""
"Idatzi edo itsatsi zure gunean exekutatu nahi zenukeen javascript kodea. "
"Javascriptaren lotura HTMLren behe partean itsatsiko da eta \"&lt;forum "
"url&gt;/custom.js\" helbidetik emango da. Mesedez, kontutan izan zure "
"javascript kodeak gunearen zenbat gaitasun ito ditzakeela eta zenbat "
"nabigatzaileek eman dezaketen erantzuna beharbada ez dela egonkorra izango "
"(<strong>pertsonalizatu modua aktibatzeko<strong>, sakatu \"Gehitu "
"javascript pertsonalizatua\"goi aldeko zeldan)."

