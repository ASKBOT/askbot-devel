"installed on your server in its own directory."
msgstr ""
"Pro povolení této funkce musí být na vašem serveru nainstalován <a "
"href=\"%(url)s\">mathjax</a>."

#: askbot/conf/markup.py:71
msgid "Base url of MathJax deployment"
msgstr "Adresa instalace MathJaxu"

#: askbot/conf/markup.py:73
