msgstr ""

#: askbot/conf/rate_limiting.py:29
msgid "Rate-limit allowlist (IPs / CIDR ranges)"
msgstr ""

#: askbot/conf/rate_limiting.py:32
msgid ""
"IP addresses and CIDR ranges that bypass every rate-limit policy (request, "
"registration, watched-user-post). One entry per row. Plain IP (1.2.3.4, "
"2001:db8::1) or CIDR (1.2.3.0/24, 2001:db8::/32). IPv4 or IPv6. Whitespace "
"is trimmed. Invalid entries are logged and skipped — no restart needed. "
"Combines with the deploy-time ASKBOT_INTERNAL_IPS django setting by union "
"(an IP bypasses if matched by either source). The admin UI shows only this "
"livesetting half; inspect settings.py or ask your deployer for the deploy-"
"time ASKBOT_INTERNAL_IPS value. Edits apply on the next request and do NOT "
"invalidate any rate-limit buckets — the allowlist is a short-circuit, not "
"part of the cache key."
msgstr ""

#: askbot/conf/rate_limiting.py:53
msgid "Subnet granularity for IP-keyed rate limits"
msgstr ""

#: askbot/conf/rate_limiting.py:57
msgid ""
"Controls how broadly IP-keyed rate limits group addresses. \"host\" buckets "
"each IP separately (/32 IPv4, /128 IPv6) — strict. \"subnet\" buckets local-"
"network neighbors together (/24 IPv4, /64 IPv6) — recommended default; "
"defends against per-IP rotation within one subnet. \"region\" buckets entire "
"regional blocks together (/16 IPv4, /48 IPv6) — aggressive. IPv4 and IPv6 "
"widths always change together. Changing this value starts fresh buckets for "
"every IP (the prefix is part of the cache key) — distinct from the allowlist "
"setting, where edits do NOT invalidate buckets."
msgstr ""

